{
  "monitor": {
    "enabled": true,
    "name": "Stitch Design Change Listener",
    "description": "Polls Google Stitch project for design changes and auto-generates component scaffolds"
  },
  "stitch": {
    "projectId": "2108938708409058757",
    "projectName": "UnifiedAITesting",
    "workspaceId": "9911504790861479393"
  },
  "polling": {
    "intervalSeconds": 30,
    "retryAttempts": 3,
    "retryDelayMs": 5000,
    "trackingMethod": "metadata-hash"
  },
  "designSystem": {
    "colors": {
      "primary": "#1976d2",
      "secondary": "#7b1fa2",
      "success": "#388e3c",
      "error": "#d32f2f",
      "warning": "#f57c00",
      "info": "#1976d2",
      "background": "#f5f5f5",
      "surface": "#ffffff",
      "text": "#212121",
      "textSecondary": "#757575"
    },
    "typography": {
      "headline": {
        "fontFamily": "Manrope",
        "fontSizes": {
          "large": "28px",
          "medium": "20px",
          "small": "16px"
        }
      },
      "body": {
        "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "fontSizes": {
          "large": "16px",
          "medium": "14px",
          "small": "12px"
        }
      }
    },
    "spacing": {
      "xs": "4px",
      "sm": "8px",
      "md": "16px",
      "lg": "24px",
      "xl": "32px"
    },
    "borderRadius": {
      "sm": "2px",
      "md": "4px",
      "lg": "8px",
      "full": "9999px"
    }
  },
  "componentGeneration": {
    "enabled": true,
    "framework": "React",
    "language": "TypeScript",
    "outputFormats": [
      "tsx",
      "css-modules",
      "json-mapping"
    ],
    "includeTests": true,
    "includeDocumentation": true
  },
  "assetMapping": {
    "enabled": true,
    "rules": [
      {
        "type": "form",
        "components": [
          "TextInput",
          "TextArea",
          "DatePicker",
          "Select",
          "Button"
        ]
      },
      {
        "type": "list",
        "components": [
          "ListItem",
          "ListHeader",
          "ListActions"
        ]
      },
      {
        "type": "modal",
        "components": [
          "Modal",
          "ModalHeader",
          "ModalBody",
          "ModalFooter"
        ]
      },
      {
        "type": "card",
        "components": [
          "Card",
          "CardHeader",
          "CardContent",
          "CardActions"
        ]
      }
    ]
  },
  "output": {
    "rootDirectory": "output/component-prep",
    "subdirectories": {
      "components": "components",
      "styles": "components",
      "mappings": "mappings",
      "designTokens": "design-tokens",
      "documentation": "docs"
    }
  },
  "logging": {
    "level": "info",
    "format": "json",
    "destinations": [
      "console",
      "file"
    ],
    "logFile": "output/monitoring.log"
  },
  "notifications": {
    "enabled": true,
    "channels": [
      "console",
      "file"
    ],
    "events": [
      "design-change-detected",
      "component-generated",
      "mapping-updated",
      "error-occurred"
    ]
  },
  "schedule": {
    "startTime": "immediately",
    "stopTime": "never",
    "daysActive": [
      "monday",
      "tuesday",
      "wednesday",
      "thursday",
      "friday"
    ]
  }
}
