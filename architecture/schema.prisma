// Prisma Schema for Unified AI Testing - Task Management Module
// Generated by Technical Architect Review of User Journey Maps & Wireframes
// Date: July 2, 2026
// Story: UN-1 (Create Individual Task) - Foundation Schema

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================================
// AUTHENTICATION & USER MANAGEMENT
// ============================================================================

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String?
  password      String      @db.Text
  role          UserRole    @default(MEMBER)
  status        UserStatus  @default(ACTIVE)

  // Relations
  createdTasks  Task[]      @relation("CreatedTasks")
  assignedTasks Task[]      @relation("AssignedTasks")
  auditLogs     AuditLog[]  @relation("AuditByUser")
  sessions      Session[]

  // Metadata
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  lastLoginAt   DateTime?

  @@index([email])
  @@index([status])
  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

model Session {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Session data
  token         String      @unique @db.Text
  ipAddress     String?
  userAgent     String?
  expiresAt     DateTime

  // Metadata
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

// ============================================================================
// CORE TASK MANAGEMENT - UN-1 PRIMARY MODELS
// ============================================================================

model Task {
  id            String      @id @default(cuid())
  title         String      @db.VarChar(255)
  description   String?     @db.Text
  dueDate       DateTime?

  // Status & Priority
  status        TaskStatus  @default(NOT_STARTED)
  priority      Priority    @default(MEDIUM)

  // Ownership & Assignment
  ownerId       String
  owner         User        @relation("CreatedTasks", fields: [ownerId], references: [id], onDelete: Restrict)
  assigneeId    String?
  assignee      User?       @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)

  // Versioning & Concurrency Control
  version       Int         @default(1)

  // Relations - Task Dependencies (UN-7)
  parentTaskId  String?
  parentTask    Task?       @relation("ChildTasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  childTasks    Task[]      @relation("ChildTasks")
  blockedBy     Task[]      @relation("BlockedByTasks", "blocking")
  blocks        Task[]      @relation("BlockedByTasks", "blocked")

  // Relations - Audit Trail
  auditLogs     AuditLog[]

  // Relations - Tags & Labels (UN-9)
  tags          Tag[]       @relation("TaskTags")

  // Relations - Comments (Future)
  comments      Comment[]

  // Relations - Attachments (Future)
  attachments   Attachment[]

  // Relations - Activity
  activities    Activity[]

  // Metadata
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  completedAt   DateTime?

  // Indexes for Query Performance
  @@index([ownerId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([parentTaskId])
  @@index([createdAt])
  @@map("tasks")
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  COMPLETED
  CANCELLED
  DRAFT
}

enum Priority {
  LOWEST
  LOW
  MEDIUM
  HIGH
  HIGHEST
  URGENT
}

// ============================================================================
// AUDIT & COMPLIANCE
// ============================================================================

model AuditLog {
  id            String      @id @default(cuid())

  // What changed
  taskId        String
  task          Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Who made the change
  userId        String
  user          User        @relation("AuditByUser", fields: [userId], references: [id], onDelete: Restrict)

  // Action details
  action        AuditAction
  changes       Json?       @db.Text // Stores old/new values as JSON

  // Additional context
  ipAddress     String?
  userAgent     String?

  // Metadata
  createdAt     DateTime    @default(now())

  @@index([taskId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

enum AuditAction {
  TASK_CREATED
  TASK_UPDATED
  TASK_DELETED
  TASK_ASSIGNED
  TASK_REASSIGNED
  STATUS_CHANGED
  PRIORITY_CHANGED
  TAG_ADDED
  TAG_REMOVED
  COMMENT_ADDED
  COMMENT_EDITED
  COMMENT_DELETED
}

// ============================================================================
// TAGGING & CATEGORIZATION - UN-9
// ============================================================================

model Tag {
  id            String      @id @default(cuid())
  name          String      @unique @db.VarChar(50)
  color         String?     @db.VarChar(7) // Hex color code
  description   String?

  // Relations
  tasks         Task[]      @relation("TaskTags")

  // Metadata
  createdAt     DateTime    @default(now())

  @@index([name])
  @@map("tags")
}

// ============================================================================
// COMMENTS & COLLABORATION
// ============================================================================

model Comment {
  id            String      @id @default(cuid())
  content       String      @db.Text

  // Relations
  taskId        String
  task          Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId      String
  author        User        @relation(fields: [authorId], references: [id], onDelete: Restrict)

  // Threading support
  parentId      String?
  parent        Comment?    @relation("CommentThreads", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]   @relation("CommentThreads")

  // Metadata
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  editedBy      String?
  editedAt      DateTime?

  @@index([taskId])
  @@index([authorId])
  @@index([parentId])
  @@map("comments")
}

// ============================================================================
// ATTACHMENTS & FILE MANAGEMENT
// ============================================================================

model Attachment {
  id            String      @id @default(cuid())
  fileName      String
  fileType      String      @db.VarChar(50)
  fileSize      BigInt
  s3Key         String      @unique

  // Relations
  taskId        String
  task          Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById  String
  uploadedBy    User        @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  // Metadata
  createdAt     DateTime    @default(now())

  @@index([taskId])
  @@index([uploadedById])
  @@map("attachments")
}

// ============================================================================
// ACTIVITY STREAM & NOTIFICATIONS
// ============================================================================

model Activity {
  id            String      @id @default(cuid())
  type          ActivityType

  // Relations
  taskId        String
  task          Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actorId       String
  actor         User        @relation(fields: [actorId], references: [id], onDelete: Restrict)

  // Metadata
  description   String      @db.Text
  data          Json?
  createdAt     DateTime    @default(now())

  @@index([taskId])
  @@index([actorId])
  @@index([type])
  @@index([createdAt])
  @@map("activities")
}

enum ActivityType {
  TASK_CREATED
  TASK_UPDATED
  TASK_ASSIGNED
  STATUS_CHANGED
  PRIORITY_CHANGED
  DUE_DATE_SET
  COMMENT_ADDED
  ATTACHMENT_ADDED
  TAG_ADDED
}

// ============================================================================
// TASK TEMPLATES & WORKFLOWS - UN-10
// ============================================================================

model TaskTemplate {
  id            String      @id @default(cuid())
  name          String      @db.VarChar(255)
  description   String?     @db.Text

  // Template fields
  defaultTitle  String?     @db.VarChar(255)
  defaultDescription String? @db.Text
  defaultPriority Priority  @default(MEDIUM)
  defaultTags   Json?       // Array of tag names

  // Category
  category      String      @db.VarChar(50)
  isActive      Boolean     @default(true)

  // Metadata
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("task_templates")
}

// ============================================================================
// TASK STATUS WORKFLOW - UN-5
// ============================================================================

model TaskStatusWorkflow {
  id            String      @id @default(cuid())

  // Status transition
  fromStatus    TaskStatus
  toStatus      TaskStatus

  // Permissions
  allowedRoles  Json        // Array of UserRole values

  // Validation
  requiredFields Json?      // Array of field names that must be filled

  // Metadata
  createdAt     DateTime    @default(now())

  @@unique([fromStatus, toStatus])
  @@map("task_status_workflows")
}

// ============================================================================
// NOTIFICATIONS - UN-6
// ============================================================================

model Notification {
  id            String      @id @default(cuid())
  type          NotificationType

  // Recipients
  recipientId   String
  recipient     User        @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  // Task context
  taskId        String?

  // Message
  title         String
  message       String      @db.Text

  // Status
  isRead        Boolean     @default(false)
  readAt        DateTime?

  // Metadata
  createdAt     DateTime    @default(now())

  @@index([recipientId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_UNASSIGNED
  TASK_DUE_SOON
  TASK_OVERDUE
  COMMENT_MENTION
  STATUS_CHANGED
  ASSIGNED_TASK_UPDATED
}

// ============================================================================
// SYSTEM CONFIGURATION
// ============================================================================

model SystemConfig {
  id            String      @id @default(cuid())
  key           String      @unique
  value         String      @db.Text
  description   String?

  // Metadata
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("system_config")
}

// ============================================================================
// ANALYTICS & REPORTING - UN-11
// ============================================================================

model TaskMetric {
  id            String      @id @default(cuid())

  // Task reference
  taskId        String

  // Metrics
  timeToStart   Int?        // Minutes from creation to start
  timeToComplete Int?       // Minutes from creation to completion
  statusChanges Int         @default(0)
  assignmentChanges Int      @default(0)
  commentCount  Int         @default(0)

  // Metadata
  date          DateTime    @default(now())

  @@index([taskId])
  @@index([date])
  @@map("task_metrics")
}

model UserMetric {
  id            String      @id @default(cuid())

  // User reference
  userId        String

  // Metrics
  tasksCreated  Int         @default(0)
  tasksCompleted Int        @default(0)
  averageTimeToComplete Float?
  activeTaskCount Int       @default(0)
  overdueTaskCount Int      @default(0)

  // Metadata
  date          DateTime    @default(now())

  @@index([userId])
  @@index([date])
  @@map("user_metrics")
}
