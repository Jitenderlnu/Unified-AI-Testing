        "tags": ["critical", "api"],
        "alert_on_failure": true,
        "severity": "critical"
      },
      {
        "name": "database_connectivity",
        "type": "tcp",
        "host": "staging-db-4521.c9akciq32.us-east-1.rds.amazonaws.com",
