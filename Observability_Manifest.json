  "error_catching": {
    "enabled": true,
    "log_level": "ERROR",
    "capture_stack_traces": true,
    "capture_context": true,
    "capture_user_info": true,
    "error_types": [
      {
        "name": "ApplicationError",
        "alert_threshold": 10,
        "time_window_minutes": 5,
        "severity": "high"
      },
      {
        "name": "DatabaseError",
        "alert_threshold": 5,
        "time_window_minutes": 5,
        "severity": "critical"
      },
      {
        "name": "ValidationError",
        "alert_threshold": 50,
        "time_window_minutes": 5,
        "severity": "low"
      },
      {
        "name": "AuthenticationError",
        "alert_threshold": 20,
        "time_window_minutes": 5,
        "severity": "high"
      },
      {
        "name": "TimeoutError",
        "alert_threshold": 5,
        "time_window_minutes": 5,
        "severity": "high"
      },
      {
        "name": "RateLimitError",
        "alert_threshold": 100,
        "time_window_minutes": 5,
        "severity": "medium"
      }
    ],
    "error_tracking": {
      "enabled": true,
      "group_by": ["error_type", "service", "endpoint"],
      "fingerprinting": true,
      "auto_deduplicate": true,
      "retention_days": 90
    }
  },
  "alert_thresholds": {
    "enabled": true,
    "notification_channels": [
      {
        "name": "slack_critical",
        "type": "slack",
        "channel": "#production-critical",
        "mention": "@on-call-sre",
        "for_severity": ["critical"]
      },
      {
        "name": "slack_alerts",
        "type": "slack",
        "channel": "#production-alerts",
        "mention": "@sre-team",
        "for_severity": ["high", "medium"]
      },
      {
        "name": "pagerduty",
        "type": "pagerduty",
        "integration_key": "{{PAGERDUTY_KEY}}",
        "for_severity": ["critical"]
      },
      {
        "name": "email",
        "type": "email",
        "recipients": ["sre-team@company.com"],
        "for_severity": ["critical", "high"]
      }
    ],
    "alert_rules": [
      {
        "id": "error_rate_spike",
        "name": "Error Rate Spike",
        "metric": "trace.web.request.errors",
        "comparison": "above",
        "threshold": 2.0,
        "threshold_duration": 300,
        "unit": "percent",
        "aggregation": "sum",
        "severity": "critical",
        "tags": ["application"],
        "notification_channels": ["slack_critical", "pagerduty"],
        "action": "page_oncall"
      },
      {
        "id": "high_latency",
        "name": "High API Latency",
        "metric": "trace.web.request.duration.by.service_name",
        "comparison": "above",
        "threshold": 300,
        "threshold_duration": 300,
        "unit": "milliseconds",
        "percentile": 95,
        "aggregation": "avg",
        "severity": "high",
        "tags": ["performance"],
        "notification_channels": ["slack_alerts"],
        "action": "investigate"
      },
      {
        "id": "database_latency",
        "name": "Database Query Slow",
        "metric": "trace.postgres.query.duration",
        "comparison": "above",
        "threshold": 100,
        "threshold_duration": 300,
        "unit": "milliseconds",
        "percentile": 95,
        "aggregation": "avg",
        "severity": "high",
        "tags": ["database"],
        "notification_channels": ["slack_alerts"],
        "action": "investigate"
      },
      {
        "id": "cpu_high",
        "name": "High CPU Utilization",
        "metric": "system.cpu.user",
        "comparison": "above",
        "threshold": 85,
        "threshold_duration": 300,
        "unit": "percent",
        "aggregation": "avg",
        "severity": "high",
        "tags": ["infrastructure"],
        "notification_channels": ["slack_alerts"],
        "action": "scale_or_investigate"
      },
      {
        "id": "memory_high",
        "name": "High Memory Utilization",
        "metric": "system.mem.pct_usable",
        "comparison": "below",
        "threshold": 15,
        "threshold_duration": 300,
        "unit": "percent",
        "aggregation": "avg",
        "severity": "high",
        "tags": ["infrastructure"],
        "notification_channels": ["slack_alerts"],
        "action": "scale_or_investigate"
      },
      {
        "id": "disk_full",
        "name": "Disk Space Critical",
        "metric": "system.disk.pct_used",
        "comparison": "above",
        "threshold": 90,
        "threshold_duration": 60,
        "unit": "percent",
        "aggregation": "avg",
        "severity": "critical",
        "tags": ["infrastructure"],
        "notification_channels": ["slack_critical", "pagerduty"],
        "action": "immediate_action"
      },
      {
        "id": "service_down",
        "name": "Service Down",
        "metric": "up",
        "comparison": "equals",
        "threshold": 0,
        "threshold_duration": 30,
        "unit": "boolean",
        "aggregation": "avg",
        "severity": "critical",
        "tags": ["critical", "application"],
        "notification_channels": ["slack_critical", "pagerduty", "email"],
        "action": "page_oncall_immediately"
      },
      {
        "id": "auth_failures",
        "name": "Authentication Failures Spike",
        "metric": "trace.auth.failure.count",
        "comparison": "above",
        "threshold": 20,
        "threshold_duration": 300,
        "unit": "count",
        "aggregation": "sum",
        "severity": "high",
        "tags": ["security"],
        "notification_channels": ["slack_alerts", "pagerduty"],
        "action": "investigate_security"
      },
      {
        "id": "rate_limit_exceeded",
        "name": "Rate Limit Exceeded",
        "metric": "trace.rate_limit.exceeded.count",
        "comparison": "above",
        "threshold": 100,
        "threshold_duration": 300,
        "unit": "count",
        "aggregation": "sum",
        "severity": "medium",
        "tags": ["performance"],
        "notification_channels": ["slack_alerts"],
        "action": "investigate"
      },
      {
        "id": "ssl_certificate_expiring",
        "name": "SSL Certificate Expiring Soon",
        "metric": "ssl.certificate.days_until_expiry",
        "comparison": "below",
        "threshold": 30,
        "threshold_duration": 0,
        "unit": "days",
        "aggregation": "min",
        "severity": "high",
        "tags": ["security"],
        "notification_channels": ["slack_alerts", "email"],
        "action": "renew_certificate"
      }
    ]
  },
  "dashboards": [
    {
      "id": "prod_overview",
      "name": "Production Overview",
      "description": "High-level view of production system health",
      "widgets": [
        {
          "type": "timeseries",
          "title": "Request Rate",
          "query": "sum:trace.web.request.hits{env:prod}",
          "display": "line"
        },
        {
          "type": "timeseries",
          "title": "Error Rate",
          "query": "sum:trace.web.request.errors{env:prod}",
          "display": "line"
        },
        {
          "type": "gauge",
          "title": "CPU Usage",
          "query": "avg:system.cpu.user{env:prod}",
          "min": 0,
          "max": 100
        },
        {
          "type": "gauge",
          "title": "Memory Usage",
          "query": "avg:system.mem.pct_usable{env:prod}",
          "min": 0,
          "max": 100
        },
        {
          "type": "timeseries",
          "title": "API Latency (p95)",
          "query": "p95:trace.web.request.duration{env:prod}",
          "display": "line"
        },
        {
          "type": "timeseries",
          "title": "Database Query Time",
          "query": "p95:trace.postgres.query.duration{env:prod}",
          "display": "area"
        }
      ]
    },
    {
      "id": "prod_errors",
      "name": "Error Analysis",
      "description": "Detailed error tracking and debugging",
      "widgets": [
        {
          "type": "table",
          "title": "Top Errors",
          "query": "select error_message, count() as error_count from errors group by error_message order by error_count desc limit 10"
        },
        {
          "type": "heatmap",
          "title": "Error Distribution Over Time",
          "query": "sum:trace.errors{env:prod} by {error_type}"
        },
        {
          "type": "table",
          "title": "Recently Seen Errors",
          "query": "select * from errors order by timestamp desc limit 20"
        }
      ]
    },
    {
      "id": "prod_performance",
      "name": "Performance Metrics",
      "description": "Performance monitoring and optimization",
      "widgets": [
        {
          "type": "timeseries",
          "title": "Response Time Distribution",
          "query": "trace.web.request.duration{env:prod}",
          "display": "stacked_area"
        },
        {
          "type": "heatmap",
          "title": "Latency by Endpoint",
          "query": "avg:trace.web.request.duration{env:prod} by {resource_name}"
        },
        {
          "type": "timeseries",
          "title": "Database Connection Pool",
          "query": "avg:app.database.connections{env:prod}",
          "display": "line"
        },
        {
          "type": "timeseries",
          "title": "Cache Hit Ratio",
          "query": "avg:app.cache.hit_ratio{env:prod}",
          "display": "line"
        }
      ]
    },
    {
      "id": "prod_infrastructure",
      "name": "Infrastructure Health",
      "description": "System resources and infrastructure metrics",
      "widgets": [
        {
          "type": "timeseries",
          "title": "CPU Usage by Node",
          "query": "avg:system.cpu.user{env:prod} by {host}"
        },
        {
          "type": "timeseries",
          "title": "Memory Usage by Node",
          "query": "avg:system.mem.pct_usable{env:prod} by {host}"
        },
        {
          "type": "timeseries",
          "title": "Disk I/O",
          "query": "avg:system.io.r_s{env:prod}, avg:system.io.w_s{env:prod}"
        },
        {
          "type": "timeseries",
          "title": "Network Throughput",
          "query": "avg:system.net.bytes_sent{env:prod}, avg:system.net.bytes_rcvd{env:prod}"
        }
      ]
    }
  ],
